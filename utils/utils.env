
source_venv()
{
  # Determine which venv we are using (venv or .venv).
  if [ -d venv ]
  then
    VENV=venv
  elif [ -d .venv ]
  then
    VENV=.venv
  else
    echo "Cannot locate the Python virtual environment directory!"
    exit 1
  fi
  
  if [ -d "${VENV}/bin" ]
  then
    source "${VENV}/bin/activate"
  elif  [ -d "${VENV}/Scripts" ]
  then
    source "${VENV}/Scripts/activate"
  else
    echo "Cannot locate activate script from venv directory!"
    exit 1
  fi
}
